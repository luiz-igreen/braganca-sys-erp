import pandas as pd
from sqlalchemy import create_engine, text
import re
import os
import streamlit as st # Importado para acessar st.secrets

# --- FUNÇÕES AUXILIARES (COPIADAS DO app.py PARA CONSISTÊNCIA) ---
def clean_money_to_db(money_str):
    if isinstance(money_str, (int, float)):
        return money_str
    if not money_str:
        return None

    clean_str = str(money_str).strip()

    # Detecta o separador decimal:
    # Se houver vírgula e depois dela houver exatamente 2 dígitos, a vírgula é o decimal.
    # Caso contrário, o ponto é o decimal (se houver).
    if re.search(r',\d{2}$', clean_str): # Ex: 1.861,66
        clean_str = clean_str.replace(".", "").replace(",", ".")
    else: # Ex: 1,861.66 ou 1861.66
        clean_str = clean_str.replace(",", "") # Remove vírgulas de milhar

    clean_str = clean_str.replace("R$", "").strip() # Remove R$ e espaços

    try:
        return float(clean_str)
    except ValueError:
        return None

def format_cpf_for_db(cpf_str):
    if pd.isna(cpf_str) or not cpf_str:
        return None
    # Remove todos os caracteres não numéricos
    cpf_digits = re.sub(r'\D', '', str(cpf_str))
    # Retorna apenas os dígitos. O banco de dados deve armazenar como TEXT.
    return cpf_digits if cpf_digits else None

# --- CONFIGURAÇÃO DO BANCO DE DADOS ---
# Para usar st.secrets fora de um app Streamlit, você precisa simular o ambiente
# ou passar a DATABASE_URL diretamente.
# Para este script de importação, vamos tentar ler de st.secrets,
# mas se falhar (porque não está rodando no Streamlit), vamos tentar de uma variável de ambiente.
try:
    database_url = st.secrets["DATABASE_URL"]
except KeyError:
    database_url = os.environ.get("DATABASE_URL")
    if not database_url:
        print("ERRO: DATABASE_URL não encontrada nos Streamlit Secrets ou como variável de ambiente.")
        print("Por favor, defina a DATABASE_URL (ex: postgresql://user:pass@host:port/db) para continuar.")
        exit()

engine = create_engine(database_url)

# --- IMPORTAÇÃO DE DADOS GERAIS DOS COLABORADORES ---
def import_cadastro_geral_colaborador(file_path):
    print(f"\n--- Iniciando importação de {file_path} para cadastro_geral_colaborador ---")
    try:
        # Tenta ler o CSV com o delimitador correto
        df = pd.read_csv(file_path, sep=',')

        # Verifica se o CSV foi lido como uma única coluna e tenta corrigir
        if len(df.columns) == 1 and df.columns[0].count(',') > 0:
            print("Detectado CSV com uma única coluna. Tentando dividir...")
            df = pd.read_csv(file_path, sep=',', header=None)
            # A primeira linha é o cabeçalho
            df.columns = df.iloc[0]
            df = df[1:].reset_index(drop=True)
            print("CSV dividido com sucesso.")

        # Padronizar nomes de colunas para minúsculas e sem acentos/caracteres especiais
        df.columns = [re.sub(r'[^a-z0-9_]', '', col.lower().replace(' ', '_').replace('(esocial)', 'esocial')) for col in df.columns]

        # Mapeamento das colunas da planilha para as colunas do banco de dados
        # Assegura que 'id' é tratado como string para evitar problemas com IDs como '123.0'
        df['id'] = df['id'].astype(str).str.replace('.0', '', regex=False)

        # Preparar DataFrame para inserção
        df_to_insert = pd.DataFrame()
        df_to_insert['id'] = df['id']
        df_to_insert['nome'] = df['nome']
        df_to_insert['cpf'] = df['cpf'].apply(format_cpf_for_db)
        df_to_insert['cargo'] = df['cargo']
        df_to_insert['status_esocial'] = df['status_esocial']
        df_to_insert['salario_mes_12_24'] = df['salario_mes_12_24'].apply(clean_money_to_db)

        # Colunas que não estão na planilha, serão preenchidas com NULL
        df_to_insert['admissao'] = None
        df_to_insert['demissao'] = None
        df_to_insert['salario_hora_12_24'] = None

        # Remover linhas onde o 'id' é nulo ou vazio, pois é a chave primária
        df_to_insert.dropna(subset=['id'], inplace=True)
        df_to_insert = df_to_insert[df_to_insert['id'] != '']

        print(f"Total de registros a serem importados: {len(df_to_insert)}")

        with engine.begin() as conn:
            # Limpar a tabela antes de inserir novos dados (opcional, mas recomendado para reimportação)
            conn.execute(text("DELETE FROM cadastro_geral_colaborador"))
            print("Tabela 'cadastro_geral_colaborador' limpa.")

            # Inserir dados
            for index, row in df_to_insert.iterrows():
                try:
                    conn.execute(
                        text("""
                            INSERT INTO cadastro_geral_colaborador (
                                id, nome, cpf, cargo, admissao, demissao, status_esocial,
                                salario_mes_12_24, salario_hora_12_24
                            ) VALUES (
                                :id, :nome, :cpf, :cargo, :admissao, :demissao, :status_esocial,
                                :salario_mes_12_24, :salario_hora_12_24
                            ) ON CONFLICT (id) DO UPDATE SET
                                nome = EXCLUDED.nome,
                                cpf = EXCLUDED.cpf,
                                cargo = EXCLUDED.cargo,
                                admissao = EXCLUDED.admissao,
                                demissao = EXCLUDED.demissao,
                                status_esocial = EXCLUDED.status_esocial,
                                salario_mes_12_24 = EXCLUDED.salario_mes_12_24,
                                salario_hora_12_24 = EXCLUDED.salario_mes_12_24
                        """),
                        row.to_dict()
                    )
                except Exception as e:
                    print(f"Erro ao inserir/atualizar registro {row['id']}: {e}")
            print(f"Importação de {len(df_to_insert)} registros para 'cadastro_geral_colaborador' concluída.")

    except FileNotFoundError:
        print(f"ERRO: Arquivo {file_path} não encontrado.")
    except Exception as e:
        print(f"ERRO durante a importação de {file_path}: {e}")

# --- Execução principal ---
if __name__ == "__main__":
    # Importar dados gerais dos colaboradores
    import_cadastro_geral_colaborador('20260609T0140_exportVisaoGral.csv')

    print("\n--- Próximo passo: Analisar e importar as outras planilhas (Histórico Mensal e Lançamento de Prêmios) ---")
    print("Por favor, revise o resultado desta importação e me diga quando estiver pronto para a próxima planilha.")
